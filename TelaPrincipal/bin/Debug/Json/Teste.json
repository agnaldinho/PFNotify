  "Query": "SELECT t0.DAT_HORA AS ABASTECIMENTO_AUTOMACAO_DAT_HO, t0.TURNO_ID AS ABASTECIMENTO_AUTOMACAO_TURNO_, t0.PDV_ID AS ABASTECIMENTO_AUTOMACAO_PDV_ID, t0.DAT_HORA_MOVIMENTO AS ABASTECIMENTO_AUTOMACAO_DAT_HO FROM ABASTECIMENTO_AUTOMACAO t0 WHERE t0.DAT_MOVIMENTO BETWEEN @dataInicial AND @dataFinal",
