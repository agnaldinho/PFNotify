{
  "Nome": "Relatorio_automacao",
  "Descricao": "Gerado pelo sistema",
  "Query": "SELECT t0.EMPRESA_ID AS ABASTECIMENTO_AUTOMACAO_EMPRES, t0.ABASTECIMENTO_AUTOMACAO_ID AS ABASTECIMENTO_AUTOMACAO_ABASTE, t0.DAT_HORA AS ABASTECIMENTO_AUTOMACAO_DAT_HO FROM ABASTECIMENTO_AUTOMACAO t0 WHERE t0.DAT_HORA BETWEEN @dataInicial AND @dataFinal",
